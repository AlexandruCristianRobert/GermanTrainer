{
  "name": "german-trainer",
  "private": true,
  "version": "1.11.20",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "predeploy": "npm run build && node -e \"require('fs').writeFileSync('dist/.nojekyll', '')\"",
    "deploy": "gh-pages -d dist --dotfiles",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@google/genai": "^1.51.0",
    "@vueuse/core": "^11.3.0",
    "dexie": "^4.0.10",
    "echarts": "^6.1.0",
    "naive-ui": "^2.40.1",
    "vue": "^3.5.13",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.5.0",
    "vue3-calendar-heatmap": "^2.0.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "fake-indexeddb": "^6.0.0",
    "gh-pages": "^6.3.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.1.10"
  }
}
